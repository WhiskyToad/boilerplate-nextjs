{
  "manifest_version": 3,
  "name": "DemoFlow - Interactive Demo Recorder",
  "version": "0.0.1",
  "description": "Record interactive product demos with click-through functionality. Create engaging demos in minutes.",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "background",
    "scripting",
    "webNavigation"
  ],

  "host_permissions": ["https://*/*", "http://*/*"],

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": [
        "content/types.js",
        "content/overlay-ui.js",
        "content/auth-bridge.js",
        "content/capture-handler.js",
        "content/content.js"
      ],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "DemoFlow Recorder",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },

  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/styles/*.css", "content/*.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://*.vercel.app/*",
      "https://your-domain.com/*"
    ]
  }
}
